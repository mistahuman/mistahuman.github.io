---
import { Github, Calendar, Eye } from '@lucide/svelte';
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
  /**
   * preview - live iframe preview on top
   * compact - denser variant for templates
   */
  variant?: 'preview' | 'compact';
}

const { project, variant = 'preview' } = Astro.props;

const showPreview = variant === 'preview' && !!project.liveUrl;
const titleClass = variant === 'compact' ? 'font-semibold text-sm' : 'font-semibold';
const descriptionClass = variant === 'compact' ? 'text-xs' : 'text-sm';
---

<article
  class="card preset-filled-surface-100-900 border border-surface-200-800 card-hover overflow-hidden flex flex-col"
>
  {
    showPreview && (
      <div class="relative h-40 bg-surface-200-800 overflow-hidden shrink-0">
        <iframe
          src={project.liveUrl}
          class="w-full h-full scale-[0.25] origin-top-left"
          style="width: 400%; height: 400%; pointer-events: none;"
          loading="lazy"
          title={`Preview of ${project.title}`}
        />
      </div>
    )
  }

  <div class="p-5 flex flex-col flex-1 gap-3">
    <div class="flex-1 space-y-2">
      <h3 class={titleClass}>{project.title}</h3>
      <p class={`${descriptionClass} text-surface-600-400`}>{project.description}</p>
      <div class="flex flex-wrap gap-1">
        {
          project.tech.map((tech) => (
            <span class="chip chip-xs preset-outlined-primary-500">{tech}</span>
          ))
        }
      </div>
    </div>

    <footer class="flex items-center justify-between gap-3">
      <span class="text-xs text-surface-600-400 flex items-center gap-1">
        <Calendar class="w-3 h-3" />
        {project.date}
      </span>
      <div class="flex gap-2">
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm preset-filled-primary-500"
              aria-label={`Live demo of ${project.title}`}
            >
              <Eye class="w-4 h-4" />
            </a>
          )
        }
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm preset-outlined-primary-500"
          aria-label={`${project.title} on GitHub`}
        >
          <Github class="w-4 h-4" />
        </a>
      </div>
    </footer>
  </div>
</article>
