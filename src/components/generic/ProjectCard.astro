---
import { Github, ExternalLink, Calendar } from '@lucide/svelte';
import { lifecycleMeta, type Project } from '../../data/projects';

interface Props {
  project: Project;
  /**
   * app - full card for web projects
   * compact - denser variant for templates
   */
  variant?: 'app' | 'compact';
}

const { project, variant = 'app' } = Astro.props;

const compact = variant === 'compact';

// Lifecycle badge — only where it applies (templates leave it undefined).
const badge = project.lifecycle ? lifecycleMeta[project.lifecycle] : null;
---

<article
  class="card preset-filled-surface-50-950 border border-surface-200-800 card-hover flex flex-col h-full overflow-hidden"
>
  <div class={`flex flex-col flex-1 ${compact ? 'p-4 gap-3' : 'p-5 gap-4'}`}>
    <div class="space-y-2">
      <div class="flex items-start justify-between gap-2">
        <h3 class={compact ? 'font-semibold text-sm' : 'h4 font-semibold'}>{project.title}</h3>
        {badge && <span class={`badge ${badge.class} shrink-0`}>{badge.label}</span>}
      </div>
      <p class={`text-surface-600-400 ${compact ? 'text-xs' : ''}`}>{project.description}</p>
    </div>

    <div class="flex flex-wrap gap-1.5">
      {
        project.tech.map((tech) => (
          <span class="chip preset-outlined-primary-500" style="--chip-size: var(--text-xs)">
            {tech}
          </span>
        ))
      }
    </div>

    <footer class="flex flex-wrap items-center justify-between gap-3 mt-auto pt-1">
      <span class="text-xs text-surface-600-400 flex items-center gap-1">
        <Calendar class="w-3 h-3" />
        {project.date}
      </span>
      <div class="flex flex-wrap gap-2">
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm preset-filled-primary-500"
            >
              <ExternalLink class="w-4 h-4" />
              <span>live demo</span>
            </a>
          )
        }
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm preset-outlined-primary-500"
        >
          <Github class="w-4 h-4" />
          <span>code</span>
        </a>
      </div>
    </footer>
  </div>
</article>
