---
// ProjectsFull.astro
import { getCollection } from 'astro:content';
import { Github } from '@lucide/svelte';
import ProjectCard from '@components/generic/ProjectCard.astro';
import { byDateThenTitle, categoryMeta, displayDate, type ProjectCategory } from '../data/projects';

const projects = (await getCollection('projects')).map((entry) => entry.data).sort(byDateThenTitle);

const inCategory = (category: ProjectCategory) => projects.filter((p) => p.category === category);

const appProjects = inCategory('app');
const cliProjects = inCategory('cli');
const starterProjects = inCategory('starter');
const academicProjects = inCategory('academic');
---

<div class="container mx-auto space-y-16">
  <header class="text-center space-y-4">
    <h1 class="h1">Projects</h1>
    <p class="text-surface-600-400">a collection of my recent works</p>
  </header>

  <!-- App / web projects — the showcase tier, so it carries no heading -->
  <section class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {appProjects.map((project) => <ProjectCard project={project} variant="app" />)}
    </div>
  </section>

  <!-- Command-line tools -->
  <section class="space-y-6">
    <div class="text-center space-y-2">
      <h2 class="h3"><span class="text-primary-500">//</span> {categoryMeta.cli.label}</h2>
      <p class="text-sm text-surface-600-400">{categoryMeta.cli.blurb}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cliProjects.map((project) => <ProjectCard project={project} variant="app" />)}
    </div>
  </section>

  <!-- Starters — compact tier -->
  <section class="space-y-6">
    <div class="text-center space-y-2">
      <h2 class="h3"><span class="text-primary-500">//</span> {categoryMeta.starter.label}</h2>
      <p class="text-sm text-surface-600-400">{categoryMeta.starter.blurb}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {starterProjects.map((project) => <ProjectCard project={project} variant="compact" />)}
    </div>
  </section>

  <!-- Academic / research repos — sober centered list -->
  <section class="space-y-4">
    <div class="text-center space-y-2">
      <h2 class="h3"><span class="text-primary-500">//</span> {categoryMeta.academic.label}</h2>
      <p class="text-sm text-surface-600-400">{categoryMeta.academic.blurb}</p>
    </div>
    <div class="space-y-2 max-w-2xl mx-auto">
      {
        academicProjects.map((project) => (
          <div class="card border border-surface-200-800 p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <h3 class="font-semibold text-sm">{project.title}</h3>
              <p class="text-xs text-surface-600-400 mt-0.5">{project.description}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-xs text-surface-600-400">{displayDate(project)}</span>
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm preset-outlined-primary-500"
                aria-label={`${project.title} on GitHub`}
              >
                <Github class="w-4 h-4" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <div class="text-center py-4">
    <a
      href="https://github.com/mistahuman"
      target="_blank"
      rel="noopener noreferrer"
      class="btn preset-outlined-primary-500 inline-flex items-center gap-2"
    >
      <Github class="w-4 h-4" />
      explore my GitHub
    </a>
  </div>
</div>
