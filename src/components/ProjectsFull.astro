---
// ProjectsFull.astro
import { Github, Calendar, Eye, Code } from '@lucide/svelte'
import { projects } from '../data/projects'

const webProjects = projects.filter((p) => !p.category || p.category === 'web')
const academicProjects = projects.filter((p) => p.category === 'academic')
---

<div class="container mx-auto space-y-16">
  <header class="text-center space-y-4">
    <h1 class="h1">Projects</h1>
    <p class="text-surface-600 dark:text-surface-400">a collection of my recent works</p>
  </header>

  <!-- Web projects -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      webProjects.map((project) => (
        <article class="card preset-filled-surface-100-900 border border-surface-200-800 card-hover overflow-hidden flex flex-col">
          {project.liveUrl && (
            <div class="relative h-40 bg-surface-200 dark:bg-surface-800 overflow-hidden shrink-0">
              <iframe
                src={project.liveUrl}
                class="w-full h-full scale-[0.25] origin-top-left"
                style="width: 400%; height: 400%; pointer-events: none;"
                loading="lazy"
                title={`Preview of ${project.title}`}
              />
            </div>
          )}
          <div class="p-5 flex flex-col flex-1 gap-3">
            <div class="flex-1 space-y-2">
              <h3 class="font-semibold">{project.title}</h3>
              <p class="text-sm text-surface-600 dark:text-surface-400">{project.description}</p>
              <div class="flex flex-wrap gap-1">
                {project.tech.map((tech) => (
                  <span class="chip preset-outlined-primary-500 text-xs flex items-center gap-1">
                    <Code class="w-3 h-3" />
                    <span>{tech}</span>
                  </span>
                ))}
              </div>
            </div>
            <footer class="flex items-center justify-between">
              <span class="text-xs text-surface-500 flex items-center gap-1">
                <Calendar class="w-3 h-3" />
                {project.date}
              </span>
              <div class="flex gap-2">
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" class="btn btn-sm preset-filled-primary-500" aria-label="Live demo">
                    <Eye class="w-4 h-4" />
                  </a>
                )}
                <a href={project.githubUrl} target="_blank" class="btn btn-sm preset-outlined-primary-500" aria-label="View on GitHub">
                  <Github class="w-4 h-4" />
                </a>
              </div>
            </footer>
          </div>
        </article>
      ))
    }
  </div>

  <!-- Academic / research repos -->
  <section class="space-y-4">
    <h2 class="h3 text-center">Academic & Research</h2>
    <p class="text-center text-sm text-surface-600 dark:text-surface-400">
      repos from my Master's in Nuclear and Energy Engineering at UniBO
    </p>
    <div class="space-y-2 max-w-2xl mx-auto">
      {
        academicProjects.map((project) => (
          <div class="card preset-filled-surface-100-900 border border-surface-200-800 p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <h3 class="font-semibold text-sm">{project.title}</h3>
              <p class="text-xs text-surface-600 dark:text-surface-400 mt-0.5">{project.description}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-xs text-surface-500">{project.date}</span>
              <a href={project.githubUrl} target="_blank" class="btn btn-sm preset-outlined-primary-500" aria-label="View on GitHub">
                <Github class="w-4 h-4" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <div class="text-center py-4">
    <a href="https://github.com/mistahuman" target="_blank" class="btn preset-outlined-primary-500 inline-flex items-center gap-2">
      <Github class="w-4 h-4" />
      explore my GitHub
    </a>
  </div>
</div>
