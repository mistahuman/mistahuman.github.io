---
// ProjectsFull.astro
import { Github } from '@lucide/svelte';
import ProjectCard from '@components/generic/ProjectCard.astro';
import { projects } from '../data/projects';

const webProjects = projects.filter((p) => !p.category || p.category === 'web');
const templateProjects = projects.filter((p) => p.category === 'template');
const academicProjects = projects.filter((p) => p.category === 'academic');
---

<div class="container mx-auto space-y-16">
  <header class="text-center space-y-4">
    <h1 class="h1">Projects</h1>
    <p class="text-surface-600-400">a collection of my recent works</p>
  </header>

  <!-- App / web projects — the showcase tier -->
  <section class="space-y-6">
    <!-- <div class="text-center space-y-1">
      <h2 class="h3"><span class="text-primary-500">//</span> apps</h2>
      <p class="text-sm text-surface-600-400">web apps and tools I've built</p>
    </div> -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {webProjects.map((project) => <ProjectCard project={project} variant="app" />)}
    </div>
  </section>

  <!-- Templates — compact tier -->
  <section class="space-y-6">
    <div class="text-center space-y-2">
      <h2 class="h3"><span class="text-primary-500">//</span> templates</h2>
      <p class="text-sm text-surface-600-400">
        reusable my starters for frontend, backend and fullstack projects
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {templateProjects.map((project) => <ProjectCard project={project} variant="compact" />)}
    </div>
  </section>

  <!-- Academic / research repos — sober centered list -->
  <section class="space-y-4">
    <div class="text-center space-y-2">
      <h2 class="h3"><span class="text-primary-500">//</span> academic & research</h2>
      <p class="text-sm text-surface-600-400">
        repos from my Master's in Nuclear and Energy Engineering at UniBO
      </p>
    </div>
    <div class="space-y-2 max-w-2xl mx-auto">
      {
        academicProjects.map((project) => (
          <div class="card border border-surface-200-800 p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <h3 class="font-semibold text-sm">{project.title}</h3>
              <p class="text-xs text-surface-600-400 mt-0.5">{project.description}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-xs text-surface-600-400">{project.date}</span>
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm preset-outlined-primary-500"
                aria-label={`${project.title} on GitHub`}
              >
                <Github class="w-4 h-4" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <div class="text-center py-4">
    <a
      href="https://github.com/mistahuman"
      target="_blank"
      rel="noopener noreferrer"
      class="btn preset-outlined-primary-500 inline-flex items-center gap-2"
    >
      <Github class="w-4 h-4" />
      explore my GitHub
    </a>
  </div>
</div>
